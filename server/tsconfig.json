{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true,

    "types": ["node"]
  },

  "include": ["src/**/*", "prisma/seed.ts"]
}
